# Mein template hoon — mujhe copy karke .env banao aur apni API keys bharo
# cp .env.example .env

# LLM Provider API Keys — jo provider use karna hai uski key daalo
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here

# Default provider aur model — ye wizard mein bhi set ho sakta hai
CODESAGE_PROVIDER=openai
CODESAGE_MODEL=gpt-4o-mini

# Logging level — DEBUG, INFO, WARNING, ERROR
CODESAGE_LOG_LEVEL=INFO
